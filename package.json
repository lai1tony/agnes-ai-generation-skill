    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.7.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
