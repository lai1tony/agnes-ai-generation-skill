{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Agnes AI Studio",
  "version": "0.1.0",
  "identifier": "com.agnesai.studio",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Agnes AI Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "category": "GraphicsAndDesign",
    "shortDescription": "Agnes AI text, image, and video generation studio",
    "longDescription": "A cross-platform desktop app for Agnes AI text, image, and video generation.",
    "windows": {
      "nsis": {
        "displayLanguageSelector": true,
        "installMode": "perMachine"
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
